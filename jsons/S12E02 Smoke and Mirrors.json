            ["SET", "/arkham/skipShufflingSharedDeckA", true],
            ["VAR", "$LOCATIONS", ["LIST", "Northside", "Downtown", "Southside", "French Hill", "Uptown", "Waterfront District"]],
            ["FOR_EACH_START_STOP_STEP", "$I", 0, 6, 1, [
                ["VAR", "$TOP_CARD", ["GET_TOP_CARD", "sharedDeckA"]],
                ["SET", "/cardById/$TOP_CARD.id/disableSideChange", true],
                ["DO_SPAWN_HIDDEN_AT_LOCATION_SCN", "$TOP_CARD.id", "$LOCATIONS.[$I]", -3, -3],
                ["SET", "/cardById/$TOP_CARD.id/disableSideChange", false]
            ]],
            ["ASK_SCENARIO_QUESTION_AND_CONTINUE", "Check Campaign Log.", ["LIST", "Miskatonic University burned.", "The investigators saved Miskatonic University."], "Smoke and Mirrors Scenario Question 1"]
        ],
        "Smoke and Mirrors Scenario Question 1": [
            ["LOG", "└── Campaign Log: {{$GAME.arkham.scenarioAnswer1Text}}"],
            ["COND",
                ["EQUAL", "$GAME.arkham.scenarioAnswer1", "A"],
                ["DO_SPAWN_LOCATION_SCN", "Miskatonic University: In Flames", "12155", 20, 43],
                ["EQUAL", "$GAME.arkham.scenarioAnswer1", "B"],
                ["DO_SPAWN_LOCATION_SCN", "Miskatonic University: Quiet Campus", "12156", 20, 43]
            ],
            ["DO_SPAWN_MINI_INVESTIGATORS_AT_LOCATION", "Miskatonic University", 5, 7, 3, 0],
            ["DO_PLACE_DOOM_ON_CURRENT_AGENDA_SCN", "$GAME.arkham.numPlayers"],
            ["VAR", "$FINAL_MESSAGE", "Mark of Elokoss cards are in Pile A."],
            ["DO_PUT_INTO_PLAY_FROM_PLAYER_DECK_SCN", "Dr. Henry Armitage: Head Librarian"],
            ["COND",
                ["NOT_EQUAL", "$DO_PUT_INTO_PLAY_FROM_PLAYER_DECK_SCN_RESULT", null],
                ["UPDATE_VAR", "$FINAL_MESSAGE", "{{$FINAL_MESSAGE}} Dr. Henry Armitage does not take up an ally slot during this scenario."]
            ],
            ["SET", "/arkham/finalScenarioMessage", "{{$FINAL_MESSAGE}}"],
            ["SCENARIO_INIT_CONTINUE", null]
        ]
    }
