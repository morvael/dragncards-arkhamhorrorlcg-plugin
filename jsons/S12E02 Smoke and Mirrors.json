            ["DO_SPAWN_LOCATIONS_SCN", "Downtown", ["SHUFFLE_LIST", ["LIST", "12145", "12146"]], ["LIST", 45], ["LIST", 10], 0, 1, 0], //Downtown: First Bank of Arkham, Downtown: Arkham Sanatorium
            ["DO_SPAWN_LOCATIONS_SCN", "Uptown", ["SHUFFLE_LIST", ["LIST", "12147", "12148"]], ["LIST", 20], ["LIST", 76], 0, 1, 0], //Uptown: St. Mary's Hospital, Uptown: Ye Olde Magick Shoppe
