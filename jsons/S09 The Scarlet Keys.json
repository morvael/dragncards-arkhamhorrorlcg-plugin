    "functions": {
        //checks for non-existence of the forbidden Red-Gloved Man card (02310) in player decks before actually starting a Scarlet Keys scenario
        "SCARLET_KEYS_SCENARIO_INIT": {
            "args": ["$SCENARIO_NAME", "$SCENARIO_EARLY_ACTION", "$SCENARIO_ACTION"],
            "code": [
                ["VAR", "$RED_GLOVED_MAN", ["GET_NAMED_PLAYER_DECK_CARD", "02310"]],
                ["COND",
                    ["EQUAL", "$RED_GLOVED_MAN", null],
                    ["SCENARIO_INIT", "The Scarlet Keys", "The Scarlet Keys", "$SCENARIO_NAME", "$SCENARIO_EARLY_ACTION", "$SCENARIO_ACTION"],
                    ["TRUE"],
                    ["LOG", "└── While playing this campaign, investigators cannot purchase or include The Red-Gloved Man asset (The Dunwich Legacy card 310) in their decks."]
                ]
            ]
        },
        //checks if a card can be concealed
        "SCARLET_KEYS_CAN_CONCEAL": {
            "args": ["$TARGET_PLAYER", "$TARGET_CARD_ID", "$ACTOR_PLAYER"],
            "code": [
                ["VALIDATE_PLAYER", "$TARGET_PLAYER", "SCARLET_KEYS_CAN_CONCEAL.TARGET_PLAYER"],
                ["VAR", "$TARGET_CARD", ["GET_CARD_AND_VALIDATE", "$TARGET_CARD_ID", "SCARLET_KEYS_CAN_CONCEAL.TARGET_CARD_ID"]],
                ["AND",
                    ["EQUAL", "$GAME.arkham.scenarioInit", false],
                    ["NOT_EQUAL", "$TARGET_CARD.currentFace.concealed", 0],
                    ["NOT_EQUAL", "$TARGET_CARD.currentFace.concealedId", null],
                    ["NOT_EQUAL", "$TARGET_CARD.currentFace.concealedId", ""],
                    ["OR",
                        ["EQUAL", "$TARGET_CARD.groupId", "sharedLocations"],
                        ["EQUAL", "$TARGET_CARD.groupId", "sharedScenarioReference"],
                        ["EQUAL", "$TARGET_CARD.groupId", "player1Investigator"],
                        ["EQUAL", "$TARGET_CARD.groupId", "player1Threat"],
                        ["EQUAL", "$TARGET_CARD.groupId", "player1Play"],
                        ["EQUAL", "$TARGET_CARD.groupId", "player1Hand"],
                        ["EQUAL", "$TARGET_CARD.groupId", "player2Investigator"],
                        ["EQUAL", "$TARGET_CARD.groupId", "player2Threat"],
                        ["EQUAL", "$TARGET_CARD.groupId", "player2Play"],
                        ["EQUAL", "$TARGET_CARD.groupId", "player2Hand"],
                        ["EQUAL", "$TARGET_CARD.groupId", "player3Investigator"],
                        ["EQUAL", "$TARGET_CARD.groupId", "player3Threat"],
                        ["EQUAL", "$TARGET_CARD.groupId", "player3Play"],
                        ["EQUAL", "$TARGET_CARD.groupId", "player3Hand"],
                        ["EQUAL", "$TARGET_CARD.groupId", "player4Investigator"],
                        ["EQUAL", "$TARGET_CARD.groupId", "player4Threat"],
                        ["EQUAL", "$TARGET_CARD.groupId", "player4Play"],
                        ["EQUAL", "$TARGET_CARD.groupId", "player4Hand"],
                        ["EQUAL", "$TARGET_CARD.groupId", "sharedNotInPlay"],
                        ["EQUAL", "$TARGET_CARD.groupId", "sharedVictoryDisplay"]
                    ],
                    ["SCARLET_KEYS_CAN_SPAWN_CONCEALED", "$TARGET_PLAYER", "$TARGET_CARD.currentFace.concealedId", "$ACTOR_PLAYER"]
                ]
            ]
        },
        //conceals a card (moves it to sharedOffMap and spawns required number of concealed cards in sharedLocations)
        "SCARLET_KEYS_CONCEAL": {
            "args": ["$TARGET_PLAYER", "$TARGET_CARD_ID", "$LOG_EVENT", "$ACTOR_PLAYER"],
            "code": [
                ["VALIDATE_PLAYER", "$TARGET_PLAYER", "SCARLET_KEYS_CONCEAL.TARGET_PLAYER"],
                ["VAR", "$TARGET_CARD", ["GET_CARD_AND_VALIDATE", "$TARGET_CARD_ID", "SCARLET_KEYS_CONCEAL.TARGET_CARD_ID"]],
                ["VALIDATE_BOOLEAN", "$LOG_EVENT", "SCARLET_KEYS_CONCEAL.LOG_EVENT"],
                ["COND",
                    ["SCARLET_KEYS_CAN_CONCEAL", "$TARGET_PLAYER", "$TARGET_CARD_ID", "$ACTOR_PLAYER"],
                    [
                        ["VAR", "$IDS_TO_SPAWN", ["LIST", "$TARGET_CARD.currentFace.concealedId"]],
                        ["VAR", "$DECOYS_TO_SPAWN", "$TARGET_CARD.currentFace.concealed"],
                        ["COND",
                            ["EQUAL", "$DECOYS_TO_SPAWN", -1],
                            ["UPDATE_VAR", "$DECOYS_TO_SPAWN", "$GAME.arkham.numPlayers"]
                        ],
                        ["FOR_EACH_START_STOP_STEP", "$I", 0, "$DECOYS_TO_SPAWN", 1, [
                            ["UPDATE_VAR", "$IDS_TO_SPAWN", ["APPEND", "$IDS_TO_SPAWN", "concealed_decoy"]]
                        ]],
                        ["UPDATE_VAR", "$IDS_TO_SPAWN", ["SHUFFLE_LIST", "$IDS_TO_SPAWN"]],
                        ["FOR_EACH_VAL", "$ID_TO_SPAWN", "$IDS_TO_SPAWN", [
                            ["SCARLET_KEYS_SPAWN_CONCEALED", "$TARGET_PLAYER", "$ID_TO_SPAWN", true, 1, 1, false, null]
                        ]],
                        ["MOVE_CARD", "$TARGET_CARD_ID", "sharedOffMap", -1],
                        ["DO_LOG", "$LOG_EVENT", "$ACTOR_PLAYER", "$TARGET_PLAYER", "conceal {{$TARGET_CARD.currentFace.name}}.", "conceals {{$TARGET_CARD.currentFace.name}}."]
                    ]
                ]
            ]
        },
        //checks if a concealed card can be spawned
        "SCARLET_KEYS_CAN_SPAWN_CONCEALED": {
            "args": ["$TARGET_PLAYER", "$DATABASE_ID", "$ACTOR_PLAYER"],
            "code": [
                ["VALIDATE_PLAYER", "$TARGET_PLAYER", "SCARLET_KEYS_CAN_SPAWN_CONCEALED.TARGET_PLAYER"],
                ["VALIDATE_NOT_EMPTY", "$DATABASE_ID", "SCARLET_KEYS_CAN_SPAWN_CONCEALED.DATABASE_ID"],
                ["VAR", "$MAX", 1],
                ["COND",
                    ["EQUAL", "$DATABASE_ID", "concealed_decoy"],
                    ["UPDATE_VAR", "$MAX", 14],
                    ["EQUAL", "$DATABASE_ID", "concealed_acolyte"],
                    ["UPDATE_VAR", "$MAX", 3]
                ],
                ["LESS_THAN", ["LENGTH", ["GET_NAMED_CARDS", "$DATABASE_ID"]], "$MAX"]
            ]
        },
        //spawns a concealed card at specified location
        "SCARLET_KEYS_SPAWN_CONCEALED": {
            "args": ["$TARGET_PLAYER", "$DATABASE_ID", "$SPAWN_HIDDEN", "$LEFT", "$TOP", "$LOG_EVENT", "$ACTOR_PLAYER"],
            "code": [
                ["VALIDATE_PLAYER", "$TARGET_PLAYER", "SCARLET_KEYS_SPAWN_CONCEALED.TARGET_PLAYER"],
                ["VALIDATE_NOT_EMPTY", "$DATABASE_ID", "SCARLET_KEYS_SPAWN_CONCEALED.DATABASE_ID"],
                ["VALIDATE_BOOLEAN", "$SPAWN_HIDDEN", "SCARLET_KEYS_SPAWN_CONCEALED.SPAWN_HIDDEN"],
                ["VALIDATE_GE0", "$LEFT", "SCARLET_KEYS_SPAWN_CONCEALED.LEFT"],
                ["VALIDATE_GE0", "$TOP", "SCARLET_KEYS_SPAWN_CONCEALED.TOP"],
                ["VALIDATE_BOOLEAN", "$LOG_EVENT", "SCARLET_KEYS_SPAWN_CONCEALED.LOG_EVENT"],
                ["COND",
                    ["SCARLET_KEYS_CAN_SPAWN_CONCEALED", "$TARGET_PLAYER", "$DATABASE_ID", "$ACTOR_PLAYER"],
                    [
                        ["VAR", "$CARD_NAME", ["INLINE_IF", "$SPAWN_HIDDEN", "concealed mini-card", "$CARD_DB.{{$DATABASE_ID}}.A.name"]],
                        ["DO_CREATE_CARDS", "$TARGET_PLAYER", "$CARD_NAME", "$DATABASE_ID", 1, "sharedLocations", false, null],
                        ["VAR", "$CREATED_CARD_ID", "$GAME.lastLoadedCardIds.[0]"],
                        ["WHILE",
                            ["NOT_EQUAL", ["GET_CARD_AT_LOCATION_EXCEPT", "$LEFT", "$TOP", "$CREATED_CARD_ID"], null],
                            ["INCREASE_VAR", "$LEFT", 3]
                        ],
                        ["DO_SET_CARD_LOCATION", "$CREATED_CARD_ID", "$LEFT", "$TOP"],
                        ["COND",
                            ["EQUAL", "$SPAWN_HIDDEN", true],
                            ["DO_FLIP_FACEDOWN", "$TARGET_PLAYER", "$CREATED_CARD_ID", false, null]
                        ],
                        ["DO_LOG", "$LOG_EVENT", "$ACTOR_PLAYER", "$TARGET_PLAYER", "spawn a {{$CARD_NAME}}.", "spawns a {{$CARD_NAME}}."]
                    ]
                ]
            ]
        },
        //returns a list of concealed cards that can be randomized
        "SCARLET_KEYS_GET_RANDOMIZABLE_CONCEALED_CARDS": {
            "args": [],
            "code": [
                ["FILTER_CARDS", "$CARD", ["AND",
                    ["EQUAL", "$CARD.sides.A.type", "MiniConcealed"],
                    ["EQUAL", "$CARD.groupId", "sharedLocations"]
                ]]
            ]
        },
        //checks if a concealed cards can be randomized
        "SCARLET_KEYS_CAN_RANDOMIZE_CONCEALED": {
            "args": ["$TARGET_PLAYER", "$ACTOR_PLAYER"],
            "code": [
                ["VALIDATE_PLAYER", "$TARGET_PLAYER", "SCARLET_KEYS_CAN_RANDOMIZE_CONCEALED.TARGET_PLAYER"],
                ["GREATER_EQUAL", ["LENGTH", ["SCARLET_KEYS_GET_RANDOMIZABLE_CONCEALED_CARDS"], 2]]
            ]
        },
        //starts the process of randomizing concealed cards (2+ MiniConcealed cards in sharedLocations are eligible)
        "SCARLET_KEYS_RANDOMIZE_CONCEALED": {
            "args": ["$TARGET_PLAYER", "$LOG_EVENT", "$ACTOR_PLAYER"],
            "code": [
                ["VALIDATE_PLAYER", "$TARGET_PLAYER", "SCARLET_KEYS_RANDOMIZE_CONCEALED.TARGET_PLAYER"],
                ["VALIDATE_BOOLEAN", "$LOG_EVENT", "SCARLET_KEYS_RANDOMIZE_CONCEALED.LOG_EVENT"],
                ["COND",
                    ["SCARLET_KEYS_CAN_RANDOMIZE_CONCEALED", "$TARGET_PLAYER", "$ACTOR_PLAYER"],
                    ["DO_SHOW_LIVE_SELECTION", "$TARGET_PLAYER", ["SCARLET_KEYS_GET_RANDOMIZABLE_CONCEALED_CARDS"], null, "Select 2+ concealed mini-cards to randomize.", 2, 0, false, "SCARLET_KEYS_RANDOMIZE_CONCEALED_SELECTION_CALLBACK", null, true]
                ]
            ]
        },
        //randomizes concealed cards (flips them down if needed, and randomizes them retaining their current locations)
        "SCARLET_KEYS_RANDOMIZE_CONCEALED_SELECTION_CALLBACK": {
            "args": ["$TARGET_PLAYER", "$SOURCE_CARD_ID", "$SELECTED_CARDS"],
            "code": [
                ["VALIDATE_PLAYER", "$TARGET_PLAYER", "SCARLET_KEYS_RANDOMIZE_CONCEALED_SELECTION_CALLBACK.TARGET_PLAYER"],
                ["VALIDATE_NOT_NULL", "$SELECTED_CARDS", "SCARLET_KEYS_RANDOMIZE_CONCEALED_SELECTION_CALLBACK.SELECTED_CARDS"],
                ["VAR", "$DATA", ["LIST"]],
                ["FOR_EACH_VAL", "$CARD", "$SELECTED_CARDS", [
                    ["DO_FLIP_FACEDOWN", "$TARGET_PLAYER", "$CARD.id", false, null],
                    ["VAR", "$DATA_ITEM", ["PROCESS_MAP", {"databaseId": "$CARD.sides.A.databaseId", "name": "$CARD.sides.A.name", "imageUrl": "$CARD.sides.A.imageUrl"}]],
                    ["UPDATE_VAR", "$DATA", ["APPEND", "$DATA", "$DATA_ITEM"]]
                ]],
                ["UPDATE_VAR", "$DATA", ["SHUFFLE_LIST", "$DATA"]],
                ["VAR", "$NUM", ["LENGTH", "$SELECTED_CARDS"]],
                ["FOR_EACH_START_STOP_STEP", "$I", 0, "$NUM", 1, [
                    ["SET", "/cardById/$SELECTED_CARDS.[$I].id/sides/A/databaseId", "$DATA.[$I].databaseId"],
                    ["SET", "/cardById/$SELECTED_CARDS.[$I].id/sides/A/name", "$DATA.[$I].name"],
                    ["SET", "/cardById/$SELECTED_CARDS.[$I].id/sides/A/imageUrl", "$DATA.[$I].imageUrl"]
                ]],
                ["LOGF", "└── {0} randomized {1} concealed mini-cards.", "$TARGET_PLAYER", "$NUM"]
            ]
        }
    },
    "labels": {
        "scarletKeysConcealMenu": {
            "English": "Conceal"
        },
        "scarletKeysSpawnDecoyMenu": {
            "English": "Spawn Decoy"
        },
        "scarletKeysRandomizeConcealedMenu": {
            "English": "Randomize Concealed"
        }
    }
}