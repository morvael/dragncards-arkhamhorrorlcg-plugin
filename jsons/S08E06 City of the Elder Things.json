                ["EQUAL", "$GAME.arkham.scenarioAnswer3Text", "Group Two."],
                [
                    ["LOG", "└── Voting result: The group votes to travel along the mountain ridge, toward the region Dyer and Danforth never explored (II)."],
                    ["EDGE_OF_THE_EARTH_SET_PARTNER_EXTRA_RESOURCES", "08715", 1], //Danforth: Brilliant Student
                    ["EDGE_OF_THE_EARTH_SET_PARTNER_EXTRA_RESOURCES", "08722", 1], //Takada Hiroko: Aeroplane Mechanic
                    ["EDGE_OF_THE_EARTH_SET_PARTNER_EXTRA_RESOURCES", "08716", 1]  //Eliyah Ashevak: Dog Handler
                ],
                ["EQUAL", "$GAME.arkham.scenarioAnswer3Text", "Group Three."],
                [
                    ["LOG", "└── Voting result: The group votes to follow the trail left behind by whatever creatures massacred the Elder Things (III)."],
                    ["EDGE_OF_THE_EARTH_SET_PARTNER_EXTRA_RESOURCES", "08714", 1], //Professor William Dyer: Professor of Geology
                    ["EDGE_OF_THE_EARTH_SET_PARTNER_EXTRA_RESOURCES", "08718", 1], //Avery Claypool: Antarctic Guide
                    ["EDGE_OF_THE_EARTH_SET_PARTNER_EXTRA_RESOURCES", "08719", 1]  //James "Cookie" Fredericks: Dubious Choice
                ]
            ],
