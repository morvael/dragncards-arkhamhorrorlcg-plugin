    "actionLists": {
        "City of the Elder Things Scenario Early Init": [
            ["EDGE_OF_THE_EARTH_ASK_FOR_PARTNER_STATUS", "Resolute", "City of the Elder Things Scenario Early Init Continue 1"]
        ],
        "City of the Elder Things Scenario Early Init Continue 1": [
            ["COND",
                ["EQUAL", ["EDGE_OF_THE_EARTH_GET_PARTNER_STATUS", "08717"], "KIA"], //Dr. Mala Sinha: Daring Physician
                [
                    ["FOR_EACH_VAL", "$PLAYER_I", "$PLAYER_ORDER", [
                        ["DO_CREATE_DECK_MISSING_CARD_SCN", "$PLAYER_I", "Frostbitten", "08646", 1]
                    ]]
                ]
            ],
            ["ASK_SCENARIO_QUESTION_AND_CONTINUE", "Check Campaign Log.", ["LIST", "The investigators scouted the city outskirts.", "The above is not true."], "City of the Elder Things Scenario Early Init Continue 2"]
        ],
        "City of the Elder Things Scenario Early Init Continue 2": [
            ["COND",
                ["EQUAL", "$GAME.arkham.scenarioAnswer1", "A"],
                ["LOG", "└── Campaign Log: {{$GAME.arkham.scenarioAnswer1Text}}"]
            ],
            ["COND",
                ["EQUAL", ["EDGE_OF_THE_EARTH_GET_PARTNER_STATUS", "08714"], "KIA"], //Professor William Dyer: Professor of Geology
                [
                    ["FOR_EACH_VAL", "$PLAYER_I", "$PLAYER_ORDER", [
                        ["DO_CREATE_DECK_MISSING_CARD_SCN", "$PLAYER_I", "Possessed", "08647", 1]
                    ]]
                ]
            ],
            ["COND",
                ["NOT_EQUAL", ["EDGE_OF_THE_EARTH_GET_PARTNER_STATUS", "08719"], "KIA"], //James "Cookie" Fredericks: Dubious Choice
                ["ASK_SCENARIO_QUESTION_AND_CONTINUE", "Check “Supplies Recovered” in Campaign Log.", ["LIST", "Dynamite is listed.", "The above is not true."], "City of the Elder Things Scenario Early Init Continue 3"],
                ["TRUE"],
                ["SCENARIO_SKIP_QUESTION", "City of the Elder Things Scenario Early Init Continue 3"]
            ]
        ],
        "City of the Elder Things Scenario Early Init Continue 3": [
            ["COND",
                ["EQUAL", "$GAME.arkham.scenarioAnswer2", "A"],
                ["LOG", "└── Supplies Recovered: {{$GAME.arkham.scenarioAnswer2Text}}"]
            ],
            ["COND",
                ["OR",
                    ["EQUAL", ["EDGE_OF_THE_EARTH_GET_PARTNER_STATUS", "08719"], "KIA"], //James "Cookie" Fredericks: Dubious Choice
                    ["NOT_EQUAL", "$GAME.arkham.scenarioAnswer2", "A"]
                ],
                ["DO_ADD_CHAOS_TOKENS_SCN", "chaos_frost", 1]
            ],
            ["VAR", "$GROUPS", ["LIST", 0, 0, 0]],
            ["VAR", "$MEMBERS", ["LIST", "08720", "08721", "08717", "08715", "08722", "08716", "08714", "08718", "08719"]], //Dr. Amy Kensler: Professor of Biology, Roald Ellsworth: Intrepid Explorer, Dr. Mala Sinha: Daring Physician, Danforth: Brilliant Student, Takada Hiroko: Aeroplane Mechanic, Eliyah Ashevak: Dog Handler, Professor William Dyer: Professor of Geology, Avery Claypool: Antarctic Guide, James "Cookie" Fredericks: Dubious Choice
            ["FOR_EACH_START_STOP_STEP", "$I", 0, 9, 1, [
                ["COND",
                    ["NOT_EQUAL", ["EDGE_OF_THE_EARTH_GET_PARTNER_STATUS", "$MEMBERS.[$I]"], "KIA"],
                    [
                        ["COND",
                            ["LESS_EQUAL", "$I", 2],
                            ["UPDATE_VAR", "$GROUPS", ["LIST", ["ADD", "$GROUPS.[0]", 1], "$GROUPS.[1]", "$GROUPS.[2]"]],
                            ["GREATER_EQUAL", "$I", 6],
                            ["UPDATE_VAR", "$GROUPS", ["LIST", "$GROUPS.[0]", "$GROUPS.[1]", ["ADD", "$GROUPS.[2]", 1]]],
                            ["TRUE"],
                            ["UPDATE_VAR", "$GROUPS", ["LIST", "$GROUPS.[0]", ["ADD", "$GROUPS.[1]", 1], "$GROUPS.[2]"]]
                        ]
                    ]
                ]
            ]],
            ["VAR", "$MAX_VOTES", ["MAX", "$GROUPS"]],
            ["VAR", "$WINNERS", ["LIST"]],
            ["VAR", "$NAMES", ["LIST", "Group One.", "Group Two.", "Group Three."]],
            ["FOR_EACH_START_STOP_STEP", "$I", 0, 3, 1, [
                ["COND",
                    ["EQUAL", "$GROUPS.[$I]", "$MAX_VOTES"],
                    ["UPDATE_VAR", "$WINNERS", ["APPEND", "$WINNERS", "$NAMES.[$I]"]]
                ]
            ]],
            ["COND",
                ["EQUAL", ["LENGTH", "$WINNERS"], 1],
                ["SCENARIO_SKIP_QUESTION_WITH_ANSWER", "A", "$WINNERS.[0]", "City of the Elder Things Scenario Early Init Continue 4"],
                ["TRUE"],
                ["ASK_SCENARIO_QUESTION_AND_CONTINUE", "Cast tiebreaking vote.", "$WINNERS", "City of the Elder Things Scenario Early Init Continue 4"]
            ]
        ],
        "City of the Elder Things Scenario Early Init Continue 4": [
            ["COND",
                ["EQUAL", "$GAME.arkham.scenarioAnswer3Text", "Group One."],
                [
                    ["LOG", "└── Voting result: The group votes to venture into the heart of the city where lie its greatest structures (I)."],
                    ["EDGE_OF_THE_EARTH_SET_PARTNER_EXTRA_RESOURCES", "08720", 1], //Dr. Amy Kensler: Professor of Biology
                    ["EDGE_OF_THE_EARTH_SET_PARTNER_EXTRA_RESOURCES", "08721", 1], //Roald Ellsworth: Intrepid Explorer
                    ["EDGE_OF_THE_EARTH_SET_PARTNER_EXTRA_RESOURCES", "08717", 1]  //Dr. Mala Sinha: Daring Physician
