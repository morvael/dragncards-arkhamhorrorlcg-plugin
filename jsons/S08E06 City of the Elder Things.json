                    ["DO_MOVE_NAMED_DECK_CARDS_SCN", "Terror of the Stars", "sharedEncounterDeck", 1, "sharedNotInPlay"]
                ],
                ["EQUAL", "$GAME.arkham.scenarioAnswer3Text", "Group Two."],
                [
                    ["DO_ADD_CHAOS_TOKENS_SCN", "chaos_elder_thing", 1],
                    ["DO_DELETE_ENCOUNTER_CARDS_SCN", "Terror of the Stars"],
                    ["DO_DELETE_ENCOUNTER_CARDS_SCN", "Benign Elder Thing"]
                ],
                ["EQUAL", "$GAME.arkham.scenarioAnswer3Text", "Group Three."],
                [
                    ["DO_DELETE_ENCOUNTER_CARDS_SCN", "Terror of the Stars"],
                    ["DO_DELETE_ENCOUNTER_CARDS_SCN", "Reawakened Elder Thing"]
                ]
            ],
            ["COND",
                ["EQUAL", "$GAME.arkham.scenarioDifficulty", "Hard"],
                ["DO_PLACE_DOOM_ON_CURRENT_AGENDA_SCN", 1],
                ["EQUAL", "$GAME.arkham.scenarioDifficulty", "Expert"],
                ["DO_PLACE_DOOM_ON_CURRENT_AGENDA_SCN", 2]
            ],
            ["SCENARIO_INIT_CONTINUE", null]
        ]
    },
    "functions": {
        "CITY_OF_THE_ELDER_THINGS_SELECTION_CALLBACK": {
            "args": ["$TARGET_PLAYER", "$SOURCE_CARD_ID", "$SELECTED_CARDS"],
            "code": [
                ["VALIDATE_PLAYER", "$TARGET_PLAYER", "CITY_OF_THE_ELDER_THINGS_SELECTION_CALLBACK.TARGET_PLAYER"],
                ["VALIDATE_NOT_NULL", "$SELECTED_CARDS", "CITY_OF_THE_ELDER_THINGS_SELECTION_CALLBACK.SELECTED_CARDS"],
                ["DO_SPAWN_MINI_INVESTIGATORS_AT_LOCATION", "$SELECTED_CARDS.[0].id", 1, 2, 2, 0],
                ["ACTION_LIST", "City of the Elder Things Scenario Init Continue"]
            ]
        }
    }
