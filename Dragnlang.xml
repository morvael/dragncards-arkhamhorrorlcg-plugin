    <contexts>
      <!-- A Dragnlang source file can only start with an object and also supports // EOL comments, unlike pure JSON. -->
      <context name="Dragnlang" attribute="Error">
        <DetectChar char="{" context="#pop!Object" attribute="Brace" beginRegion="object"/>
        <IncludeRules context="FindComments"/>
      </context>

      <!-- Comments with Kate's special sauce -->
      <context name="FindComments" attribute="Error">
        <DetectSpaces attribute="Whitespace"/>
        <StringDetect String="//" context="Comment" attribute="Comment"/>
      </context>

      <context name="Comment" attribute="Comment" lineEndContext="#pop">
        <DetectSpaces/>
        <IncludeRules context="##Comments"/>
        <DetectIdentifier/>
      </context>

      <!-- A typical JSON value - either a string, object, array, keyword or number. Float numbers can be styled separately from integer numbers. -->
      <context name="Value" attribute="Error">
        <DetectChar char="&quot;" context="#pop!MaybeString" attribute="Quote"/>
        <DetectChar char="{" context="#pop!Object" attribute="Brace" beginRegion="object"/>
        <DetectChar char="[" context="#pop!Array" attribute="Bracket" beginRegion="array"/>
        <keyword String="Keywords" context="#pop" attribute="Keyword"/>
        <RegExpr String="&float;" context="#pop" attribute="Float"/>
        <RegExpr String="&integer;" context="#pop" attribute="Integer"/>
        <IncludeRules context="FindComments"/>
      </context>

      <!-- JSON object. -->
      <context name="Object" attribute="Error">
        <DetectChar char="&quot;" context="#pop!ObjectAfterKey!KeyString" attribute="Quote"/>
        <DetectChar char="}" context="#pop" attribute="Brace" endRegion="object"/>
        <IncludeRules context="FindComments"/>
      </context>

      <context name="ObjectBeforeKey" attribute="Error">
        <DetectChar char="&quot;" context="#pop!ObjectAfterKey!KeyString" attribute="Quote"/>
        <IncludeRules context="FindComments"/>
      </context>

      <context name="ObjectAfterKey" attribute="Error">
        <DetectChar char=":" context="#pop!ObjectAfterValue!Value" attribute="Colon"/>
        <IncludeRules context="FindComments"/>
      </context>

      <context name="ObjectAfterValue" attribute="Error">
        <DetectChar char="," context="#pop!ObjectBeforeKey" attribute="Comma"/>
        <DetectChar char="}" context="#pop" attribute="Brace" endRegion="object"/>
        <IncludeRules context="FindComments"/>
      </context>

      <!-- JSON array. If the first element is a string, then it may be a function call. -->
      <context name="Array" attribute="Error" fallthroughContext="#pop!ArrayAfterValue!Value">
        <DetectChar char="&quot;" context="#pop!ArrayAfterValue!MaybeFunctionString" attribute="Quote"/>
        <DetectChar char="]" context="#pop" attribute="Bracket" endRegion="array"/>
        <IncludeRules context="FindComments"/>
      </context>

      <context name="ArrayAfterValue" attribute="Error">
        <DetectChar char="," context="Value" attribute="Comma"/>
        <DetectChar char="]" context="#pop" attribute="Bracket" endRegion="array"/>
        <IncludeRules context="FindComments"/>
      </context>

      <!-- Base of all string types, handles escape sequences and checking character validity. -->
      <context name="StringBase" attribute="String" lineEndContext="#pop">
        <RegExpr String="&escape;" attribute="Escape"/>
        <RegExpr String="&invalidEscape;" attribute="Error"/>
        <RegExpr String="&controlChars;" attribute="Error"/>
      </context>

      <!-- Special context where closing double quotes are expected. -->
      <context name="StringEnd" attribute="Error" lineEndContext="#pop">
        <DetectChar char="&quot;" context="#pop" attribute="Quote"/>
      </context>

      <!-- Object key. Does not support any Dragnlang features. -->
      <context name="KeyString" attribute="Key" lineEndContext="#pop">
        <DetectChar char="&quot;" context="#pop" attribute="Quote"/>
        <IncludeRules context="StringBase"/>
      </context>

      <!-- Possibly a function call, but it may also be a special string. -->
      <context name="MaybeFunctionString" attribute="Error" lineEndContext="#pop" fallthroughContext="#pop!FunctionString">
        <DetectChar char="$" context="#pop!SpecialString!VariableSegment" attribute="Variable"/>
        <DetectChar char="/" context="#pop!SpecialString!PathSegmentStart" attribute="Solidus"/>
      </context>

      <!-- Possibly a regular JSON string, but it may also be a special string. -->
      <context name="MaybeString" attribute="Error" lineEndContext="#pop" fallthroughContext="#pop!ValueString">
        <DetectChar char="$" context="#pop!SpecialString!VariableSegment" attribute="Variable"/>
        <DetectChar char="/" context="#pop!SpecialString!PathSegmentStart" attribute="Solidus"/>
      </context>

      <!-- A function call. Supports preprocessor directives (in current version of Dragnlang this isn't actually true). -->
      <context name="FunctionString" attribute="Function" lineEndContext="#pop">
        <DetectChar char="&quot;" context="#pop" attribute="Quote"/>
        <RegExpr String="&preprocessor;" context="PreprocessorSegmentStart" attribute="Preprocessor"/>
        <keyword String="Functions" context="#pop!StringEnd" attribute="Core Function" additionalDeliminator="&quot;"/>
        <IncludeRules context="StringBase"/>
      </context>

      <!-- A regular JSON string. Supports preprocessor directives. -->
      <context name="ValueString" attribute="String" lineEndContext="#pop">
        <DetectChar char="&quot;" context="#pop" attribute="Quote"/>
        <RegExpr String="&preprocessor;" context="PreprocessorSegmentStart" attribute="Preprocessor"/>
        <IncludeRules context="StringBase"/>
      </context>

      <!-- Used for special strings. Supports preprocessor directives and segments. -->
      <context name="SpecialString" attribute="Error" lineEndContext="#pop">
        <DetectChar char="&quot;" context="#pop" attribute="Quote"/>
        <DetectChar char="$" context="VariableSegment" attribute="Variable"/>
        <DetectChar char="." context="DotSegment" attribute="Dot"/>
        <DetectChar char="/" context="PathSegmentStart" attribute="Solidus"/>
        <RegExpr String="&preprocessor;" context="PreprocessorSegmentStart" attribute="Preprocessor"/>
        <IncludeRules context="StringBase"/>
      </context>

      <!-- Possibly a path segment, but it may also be a variable or index segment. -->
      <context name="DotSegment" attribute="Error" lineEndContext="#pop" fallthroughContext="#pop!PathSegment">
        <DetectChar char="$" context="#pop!VariableSegment" attribute="Variable"/>
        <RegExpr String="&index;" context="#pop!IndexSegmentStart" attribute="Index"/>
      </context>

      <!-- A variable segment. -->
      <context name="VariableSegment" attribute="Variable" lineEndContext="#pop">
        <AnyChar String="&quot;$./]}" context="#pop" lookAhead="1"/>
        <RegExpr String="&preprocessor;" context="PreprocessorSegmentStart" attribute="Preprocessor"/>
        <keyword String="Variables" attribute="Core Variable" additionalDeliminator="&quot;"/>
        <IncludeRules context="StringBase"/>
      </context>

      <!-- Possibly a path segment, but it may also be a variable segment. -->
      <context name="PathSegmentStart" attribute="Error" lineEndContext="#pop" fallthroughContext="#pop!PathSegment">
        <DetectChar char="$" context="#pop!VariableSegment" attribute="Variable"/>
      </context>

      <!-- A path segment. -->
      <context name="PathSegment" attribute="Path" lineEndContext="#pop">
        <AnyChar String="&quot;$./]}" context="#pop" lookAhead="1"/>
        <RegExpr String="&preprocessor;" context="PreprocessorSegmentStart" attribute="Preprocessor"/>
        <keyword String="Paths" attribute="Core Path" additionalDeliminator="&quot;"/>
        <IncludeRules context="StringBase"/>
      </context>

      <!-- An index segment, but it may  -->
      <context name="IndexSegmentStart" attribute="Error" lineEndContext="#pop" fallthroughContext="#pop!IndexSegment">
        <DetectChar char="$" context="VariableSegment" attribute="Variable"/>
      </context>

      <context name="IndexSegment" attribute="String" lineEndContext="#pop">
        <DetectChar char="]" context="#pop" attribute="Index"/>
        <keyword String="Keywords" context="#pop!IndexEnd" attribute="Keyword"/>
        <RegExpr String="&float;" context="#pop!IndexEnd" attribute="Float"/>
        <RegExpr String="&integer;" context="#pop!IndexEnd" attribute="Integer"/>
        <IncludeRules context="StringBase"/>
      </context>

      <context name="IndexEnd" attribute="Error" lineEndContext="#pop">
        <DetectChar char="]" context="#pop" attribute="Index"/>
      </context>

      <!-- Used for preprocessor value (variable or standard string inside {{ }}). -->
      <context name="PreprocessorSegmentStart" attribute="Error" lineEndContext="#pop" fallthroughContext="#pop!PreprocessorSegment">
        <DetectChar char="$" context="VariableSegment" attribute="Variable"/>
      </context>

      <context name="PreprocessorSegment" attribute="String" lineEndContext="#pop">
        <StringDetect String="}}" context="#pop" attribute="Preprocessor"/>
        <IncludeRules context="StringBase"/>
      </context>



    </contexts>

    <itemDatas>
      <!-- basic styles -->
      <itemData name="Whitespace"    defStyleNum="dsNormal"/>
      <itemData name="Error"         defStyleNum="dsError" underline="0" strikethrough="1"/>
      <itemData name="Comment"       defStyleNum="dsComment"/>

      <!-- JSON symbol styles -->
      <itemData name="Brace"         defStyleNum="dsOperator"/>      <!-- object opening and closing brace ({ }) -->
      <itemData name="Bracket"       defStyleNum="dsOperator"/>      <!-- array opening and closing bracket ([ ]) -->
      <itemData name="Colon"         defStyleNum="dsOperator"/>      <!-- object key value separator (:) -->
      <itemData name="Comma"         defStyleNum="dsOperator"/>      <!-- object pair and array value separator (,) -->
      <itemData name="Quote"         defStyleNum="dsOperator"/>      <!-- string opening and closing double quotes (") -->

      <!-- various JSON styles -->
      <itemData name="Keyword"       defStyleNum="dsKeyword"/>       <!-- built-in JSON keywords (null, true, false) -->
      <itemData name="Integer"       defStyleNum="dsDecVal"/>        <!-- integer number (no . and no e/E) -->
      <itemData name="Float"         defStyleNum="dsFloat"/>         <!-- float or exponent number (. and/or e/E) -->
      <itemData name="Escape"        defStyleNum="dsSpecialChar"/>   <!-- escape sequence inside any string -->

      <!-- string styles -->
      <itemData name="Key"           defStyleNum="dsDataType"/>      <!-- object key string -->
      <itemData name="Core Function" defStyleNum="dsFunction"/>      <!-- built-in function name string -->
      <itemData name="Function"      defStyleNum="dsFunction"/>      <!-- function name string -->
      <itemData name="String"        defStyleNum="dsString"/>        <!-- standard string -->

      <!-- string element styles -->
      <itemData name="Core Variable" defStyleNum="dsVariable"/>      <!-- built-in variable name -->
      <itemData name="Variable"      defStyleNum="dsVariable"/>      <!-- variable name -->
      <itemData name="Core Path"     defStyleNum="dsVariable"/>      <!-- built-in path name -->
      <itemData name="Path"          defStyleNum="dsVariable"/>      <!-- path name -->
      <itemData name="Dot"           defStyleNum="dsOperator"/>      <!-- member separator inside a special string (.) -->
      <itemData name="Solidus"       defStyleNum="dsOperator"/>      <!-- path separator inside a special string (/) -->
      <itemData name="Index"         defStyleNum="dsOperator"/>      <!-- index block opening and closing bracket inside a special string ([ ]) -->
      <itemData name="Preprocessor"  defStyleNum="dsPreprocessor"/>  <!-- preprocessor block opening and closing double braces inside a special string ({{ }}) -->
    </itemDatas>

  </highlighting>

